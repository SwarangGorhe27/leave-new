{
  "info": {
    "name": "Attendance Audit Log APIs",
    "_postman_id": "34b3cf47-f91a-4c50-b4d6-7f4d436f3be2",
    "description": "Postman collection for attendance audit log APIs.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000" },
    { "key": "company_id", "value": "11111111-1111-1111-1111-111111111111" },
    { "key": "employee_id", "value": "22222222-2222-2222-2222-222222222222" },
    { "key": "record_id", "value": "1" },
    { "key": "punch_log_id", "value": "1" },
    { "key": "auth_token", "value": "" }
  ],
  "item": [
    {
      "name": "List Audit Logs",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{auth_token}}" }
        ],
        "url": {
          "raw": "{{base_url}}/api/v1/attendance/audit-logs?company_id={{company_id}}&from_date=2026-05-01&to_date=2026-05-31&table_name=att_punch_log&action=UPDATE&action_source=HR_ADMIN",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "attendance", "audit-logs"],
          "query": [
            { "key": "company_id", "value": "{{company_id}}" },
            { "key": "from_date", "value": "2026-05-01" },
            { "key": "to_date", "value": "2026-05-31" },
            { "key": "table_name", "value": "att_punch_log" },
            { "key": "action", "value": "UPDATE" },
            { "key": "action_source", "value": "HR_ADMIN" }
          ]
        }
      }
    },
    {
      "name": "Record History",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{auth_token}}" }
        ],
        "url": {
          "raw": "{{base_url}}/api/v1/attendance/audit-logs/record/att_punch_log/{{record_id}}?company_id={{company_id}}",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "attendance", "audit-logs", "record", "att_punch_log", "{{record_id}}"],
          "query": [
            { "key": "company_id", "value": "{{company_id}}" }
          ]
        }
      }
    },
    {
      "name": "Employee Audit Logs",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{auth_token}}" }
        ],
        "url": {
          "raw": "{{base_url}}/api/v1/attendance/audit-logs/employee/{{employee_id}}?company_id={{company_id}}&from_date=2026-05-01&to_date=2026-05-31",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "attendance", "audit-logs", "employee", "{{employee_id}}"],
          "query": [
            { "key": "company_id", "value": "{{company_id}}" },
            { "key": "from_date", "value": "2026-05-01" },
            { "key": "to_date", "value": "2026-05-31" }
          ]
        }
      }
    },
    {
      "name": "Audit Summary",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{auth_token}}" }
        ],
        "url": {
          "raw": "{{base_url}}/api/v1/attendance/audit-logs/summary?company_id={{company_id}}&from_date=2026-05-01&to_date=2026-05-31",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "attendance", "audit-logs", "summary"],
          "query": [
            { "key": "company_id", "value": "{{company_id}}" },
            { "key": "from_date", "value": "2026-05-01" },
            { "key": "to_date", "value": "2026-05-31" }
          ]
        }
      }
    },
    {
      "name": "Swipe Audit Logs",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{auth_token}}" }
        ],
        "url": {
          "raw": "{{base_url}}/api/v1/attendance/audit-logs/swipe/{{punch_log_id}}?company_id={{company_id}}",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "attendance", "audit-logs", "swipe", "{{punch_log_id}}"],
          "query": [
            { "key": "company_id", "value": "{{company_id}}" }
          ]
        }
      }
    },
    {
      "name": "Export Audit Logs",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{auth_token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"company_id\": \"{{company_id}}\",\n  \"from_date\": \"2026-05-01\",\n  \"to_date\": \"2026-05-31\",\n  \"table_name\": \"att_punch_log\",\n  \"format\": \"csv\",\n  \"email_to\": \"audit@example.com\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/v1/attendance/audit-logs/export",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "attendance", "audit-logs", "export"]
        }
      }
    }
  ]
