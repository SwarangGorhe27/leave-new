{
  "info": {
    "name": "Attendance Notification APIs",
    "_postman_id": "cb2d7a0c-0dca-4fb8-a7d2-8b53e2f35f91",
    "description": "Postman collection for attendance notification APIs.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000" },
    { "key": "company_id", "value": "11111111-1111-1111-1111-111111111111" },
    { "key": "recipient_id", "value": "22222222-2222-2222-2222-222222222222" },
    { "key": "notification_id", "value": "33333333-3333-3333-3333-333333333333" },
    { "key": "reference_id", "value": "44444444-4444-4444-4444-444444444444" },
    { "key": "auth_token", "value": "" }
  ],
  "item": [
    {
      "name": "List Notifications",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{auth_token}}" }],
        "url": {
          "raw": "{{base_url}}/api/v1/attendance/notifications?company_id={{company_id}}&recipient_id={{recipient_id}}&is_read=false&notification_type=MISSING_PUNCH",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "attendance", "notifications"],
          "query": [
            { "key": "company_id", "value": "{{company_id}}" },
            { "key": "recipient_id", "value": "{{recipient_id}}" },
            { "key": "is_read", "value": "false" },
            { "key": "notification_type", "value": "MISSING_PUNCH" }
          ]
        }
      }
    },
    {
      "name": "Read Notification",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{auth_token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"company_id\": \"{{company_id}}\",\n  \"recipient_id\": \"{{recipient_id}}\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/v1/attendance/notifications/{{notification_id}}/read",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "attendance", "notifications", "{{notification_id}}", "read"]
        }
      }
    },
    {
      "name": "Read All Notifications",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{auth_token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"company_id\": \"{{company_id}}\",\n  \"recipient_id\": \"{{recipient_id}}\",\n  \"notification_type\": \"MISSING_PUNCH\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/v1/attendance/notifications/read-all",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "attendance", "notifications", "read-all"]
        }
      }
    },
    {
      "name": "Unread Count",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{auth_token}}" }],
        "url": {
          "raw": "{{base_url}}/api/v1/attendance/notifications/unread-count?company_id={{company_id}}&recipient_id={{recipient_id}}",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "attendance", "notifications", "unread-count"],
          "query": [
            { "key": "company_id", "value": "{{company_id}}" },
            { "key": "recipient_id", "value": "{{recipient_id}}" }
          ]
        }
      }
    },
    {
      "name": "Dismiss Notification",
      "request": {
        "method": "DELETE",
        "header": [
          { "key": "Authorization", "value": "Bearer {{auth_token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"company_id\": \"{{company_id}}\",\n  \"recipient_id\": \"{{recipient_id}}\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/v1/attendance/notifications/{{notification_id}}",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "attendance", "notifications", "{{notification_id}}"]
        }
      }
    },
    {
      "name": "Send Notification",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{auth_token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"company_id\": \"{{company_id}}\",\n  \"recipient_ids\": [\"{{recipient_id}}\"],\n  \"notification_type\": \"MISSING_PUNCH\",\n  \"reference_table\": \"att_punch_log\",\n  \"reference_id\": \"{{reference_id}}\",\n  \"message\": \"Missing punch detected.\",\n  \"triggered_by_id\": \"{{recipient_id}}\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/v1/attendance/notifications/send",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "attendance", "notifications", "send"]
        }
      }
    }
  ]
